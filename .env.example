# InfraMind-AI Application Environment Variables
# Copy this file to .env and update with your actual values
# Used by docker-compose.yml for backend and frontend services

# ===========================================
# Application Configuration
# ===========================================
SECRET_KEY=your-secret-key-change-in-production

# ===========================================
# PostgreSQL Database
# ===========================================
POSTGRES_HOST=inframind-postgres
POSTGRES_PORT=5432
POSTGRES_DB=inframind-ai
POSTGRES_USER=your-postgres-user
POSTGRES_PASSWORD=your-postgres-password

# ===========================================
# Redis Configuration
# ===========================================
REDIS_HOST=inframind-redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===========================================
# Vector Database Configuration
# ===========================================
# Set to 'false' to use PgVector (PostgreSQL), 'true' to use Milvus
USE_MILVUS=false

# ===========================================
# OpenWebUI / LLM Configuration
# ===========================================
OPENWEB_API_URL=http://your-openwebui-host:8081/api/v1
OPENWEB_API_KEY=your-openwebui-api-key
OPENWEB_CHAT_MODEL=models/your-chat-model.gguf
OPENWEB_EMBEDDER_MODEL=models/your-embedding-model.gguf
OPENWEB_CHAT_CONTEXT_SIZE=8192
OPENWEB_EMBEDDING_CONTEXT_SIZE=8192
EMBEDDING_DIMENSION=4096

# ===========================================
# GitHub Integration
# ===========================================
REPO_PAT_TOKEN=your-github-personal-access-token
GITHUB_HOST=github.com

# ===========================================
# Caching Configuration
# ===========================================
CACHE_ENABLED=false

# ===========================================
# Processing Configuration
# ===========================================
DEFAULT_BATCH_SIZE=4
DEFAULT_MAX_CONCURRENT=5
MAX_PARALLEL_FILES=5
MAX_CHUNK_SIZE=2000
CHUNK_OVERLAP=200
PARALLEL_CHUNKS=6
