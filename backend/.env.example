# InfraMind-AI Backend Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# REQUIRED: API Keys (from GitHub Secrets)
# ===========================================

# OpenWebUI API Key for LLM and Embedding access
OPENWEB_API_KEY=your_openwebui_api_key_here

# GitHub Personal Access Token for repository access
REPO_PAT_TOKEN=your_github_pat_token_here

# ===========================================
# OpenWebUI / LLM Configuration
# ===========================================

# OpenWebUI API URL (without trailing slash)
OPENWEB_API_URL=https://your-openwebui-instance.com/api/v1

# Default chat model
OPENWEB_CHAT_MODEL=your-chat-model-name

# Default embedding model
OPENWEB_EMBEDDER_MODEL=your-embedding-model-name

# Chat context window size
OPENWEB_CHAT_CONTEXT_SIZE=8192

# Embedding context window size
OPENWEB_EMBEDDING_CONTEXT_SIZE=8192

# Embedding vector dimension
EMBEDDING_DIMENSION=4096

# ===========================================
# Application Configuration
# ===========================================

APP_NAME=InfraMind-AI
APP_VERSION=4.0.0
DEBUG=true
LOG_LEVEL=WARNING
SECRET_KEY=change-this-to-a-secure-random-string

# ===========================================
# PostgreSQL Database
# ===========================================

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=inframind_ai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ===========================================
# Redis Configuration
# ===========================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===========================================
# Vector Database Configuration
# ===========================================

# Use Milvus (true) or PGVector/PostgreSQL (false, default)
# PGVector stores vectors in PostgreSQL (recommended for simplicity)
# Milvus is a dedicated vector database (better for large-scale deployments)
USE_MILVUS=false

# Milvus Configuration (only used if USE_MILVUS=true)
MILVUS_HOST=localhost
MILVUS_PORT=19530

# ===========================================
# Caching Configuration
# ===========================================

# Caching is DISABLED by default
CACHE_ENABLED=false
CACHE_TTL_SECONDS=3600
CACHE_EMBEDDING_TTL_SECONDS=86400

# ===========================================
# Processing Configuration
# ===========================================

# Batch processing settings
DEFAULT_BATCH_SIZE=4
DEFAULT_MAX_CONCURRENT=5
MAX_PARALLEL_FILES=5
MAX_FILES_PER_BATCH=10
MAX_DOCUMENTS_PER_BATCH=50

# Chunking settings
MAX_CHUNK_SIZE=2000
CHUNK_OVERLAP=200
MAX_DOCUMENT_SIZE_MB=10.0

# Parallel chunk processing (for embed job)
# Number of chunks to process in parallel
PARALLEL_CHUNKS=6

# ===========================================
# Chat Configuration
# ===========================================

DEFAULT_TEMPERATURE=0.7
DEFAULT_MAX_TOKENS=2000
CHAT_HISTORY_MAX_MESSAGES=20

# Top K configuration for RAG
DEFAULT_TOP_K=10
TOP_K_AUTO_MIN=5
TOP_K_AUTO_MAX=100
TOP_K_AUTO_PERCENT=0.1

# ===========================================
# GitHub Integration
# ===========================================

# GitHub host (change for GitHub Enterprise)
GITHUB_HOST=github.com
GITHUB_API_VERSION=2022-11-28

# Default exclude patterns for GitHub sync
# Separate multiple patterns with comma
DEFAULT_EXCLUDE_PATTERNS=*.pyc,*.pyo,__pycache__,*.egg-info,*.dist-info,node_modules,dist,build,.git,.svn,.hg,.idea,.vscode,*.min.js,*.min.css,package-lock.json,yarn.lock,poetry.lock,Pipfile.lock,*.lock
