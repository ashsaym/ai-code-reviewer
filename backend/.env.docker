# InfraMind-AI Backend Docker Environment Configuration
# Environment variables for Docker deployment

# ===========================================
# REQUIRED: API Keys
# ===========================================

# OpenWebUI API Key for LLM and Embedding access
OPENWEB_API_KEY=your-openwebui-api-key-here

# GitHub Personal Access Token for repository access
REPO_PAT_TOKEN=your-github-pat-token-here

# ===========================================
# OpenWebUI / LLM Configuration
# ===========================================

# OpenWebUI API URL (without trailing slash)
OPENWEB_API_URL=http://openwebui:8080/api/v1

# Default chat model
OPENWEB_CHAT_MODEL=models/Qwen3-8B-Q4_K_M.gguf

# Default embedding model
OPENWEB_EMBEDDER_MODEL=models/Qwen3-Embedding-8B-Q4_K_M.gguf

# Chat context window size
OPENWEB_CHAT_CONTEXT_SIZE=8192

# Embedding context window size
OPENWEB_EMBEDDING_CONTEXT_SIZE=8192

# Embedding vector dimension
EMBEDDING_DIMENSION=4096

# ===========================================
# Application Configuration
# ===========================================

APP_NAME=InfraMind-AI
APP_VERSION=4.0.0
DEBUG=false
LOG_LEVEL=INFO
SECRET_KEY=change-this-to-a-secure-random-key-in-production

# ===========================================
# PostgreSQL Database
# ===========================================

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=inframind-ai
POSTGRES_USER=inframind
POSTGRES_PASSWORD=change-this-secure-password

# ===========================================
# Redis Configuration
# ===========================================

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-this-redis-password
REDIS_DB=0

# ===========================================
# Vector Database Configuration
# ===========================================

# Use Milvus (true) or PGVector/PostgreSQL (false, default)
USE_MILVUS=false

# Milvus Configuration (only used if USE_MILVUS=true)
MILVUS_HOST=milvus
MILVUS_PORT=19530

# ===========================================
# Caching Configuration
# ===========================================

# Caching is DISABLED by default
CACHE_ENABLED=false
CACHE_TTL_SECONDS=3600
CACHE_EMBEDDING_TTL_SECONDS=86400

# ===========================================
# Processing Configuration
# ===========================================

# Batch processing settings
DEFAULT_BATCH_SIZE=4
DEFAULT_MAX_CONCURRENT=5
MAX_PARALLEL_FILES=5
MAX_FILES_PER_BATCH=10
MAX_DOCUMENTS_PER_BATCH=50

# Chunking settings
MAX_CHUNK_SIZE=2000
CHUNK_OVERLAP=200
MAX_DOCUMENT_SIZE_MB=10.0

# Parallel chunk processing (for embed job)
PARALLEL_CHUNKS=6

# ===========================================
# Chat Configuration
# ===========================================

DEFAULT_TEMPERATURE=0.7
DEFAULT_MAX_TOKENS=2000
CHAT_HISTORY_MAX_MESSAGES=20

# Top K configuration for RAG
DEFAULT_TOP_K=10
TOP_K_AUTO_MIN=5
TOP_K_AUTO_MAX=100
TOP_K_AUTO_PERCENT=0.1

# ===========================================
# GitHub Integration
# ===========================================

# GitHub host (change for GitHub Enterprise)
GITHUB_HOST=github.com
GITHUB_API_VERSION=2022-11-28

# Default exclude patterns for GitHub sync
DEFAULT_EXCLUDE_PATTERNS=*.pyc,*.pyo,__pycache__,*.egg-info,*.dist-info,node_modules,dist,build,.git,.svn,.hg,.idea,.vscode,*.min.js,*.min.css,package-lock.json,yarn.lock,poetry.lock,Pipfile.lock,*.lock

# ===========================================
# SSL/TLS Certificate Configuration
# ===========================================

# SSL certificate verification (set to false to disable, NOT recommended for production)
SSL_VERIFY=true

# Path to custom CA certificate file (PEM format) for self-signed certificates
# Leave empty to use system CA certificates
SSL_CA_CERT_PATH=

# Optional: Client certificate for mutual TLS authentication
# SSL_CLIENT_CERT_PATH=/path/to/client-cert.pem
# SSL_CLIENT_KEY_PATH=/path/to/client-key.pem
